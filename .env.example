# URL til Drivees AMPECO-instans - fås fra Drivee (krk@drivee.dk)
AMPECO_API_URL=https://{tenant}.ampeco.com/public-api

# Bearer Token - fås fra Drivee Customer Support eller via AMPECO back-office
AMPECO_BEARER_TOKEN=your_token_here

# Monta AFIR API credentials - ansøg via https://forms.gle/mBuYoWpcLVzKM7du8
MONTA_CLIENT_ID=your_client_id_here
MONTA_CLIENT_SECRET=your_client_secret_here

# PostgreSQL forbindelsesstreng (kræver PostGIS extension)
# Bruger port 5444 som defineret i docker-compose.yml
DATABASE_URL=postgresql://ladestander:skift-dette-password@localhost:5444/ladestander

# Password til PostgreSQL-brugeren (bruges af Docker og DATABASE_URL)
POSTGRES_PASSWORD=skift-dette-password

# Polling interval i sekunder (anbefalet: 60)
POLL_INTERVAL_SECONDS=60

# PostgREST forbindelses-URI (authenticator-rollen)
# PostgreSQL kører nu i Docker på port 5444 — brug postgres som hostname inde fra Docker-netværket
PGRST_DB_URI=postgresql://authenticator:skift-dette-password@postgres:5432/ladestander

# PostgreSQL forbindelsesstreng (kræver PostGIS extension)
DATABASE_URL=postgresql://user:password@localhost:5432/ladestander

# Polling interval i sekunder (anbefalet: 60)
POLL_INTERVAL_SECONDS=60

# PostgREST forbindelses-URI (authenticator-rollen)
# Brug host.docker.internal i stedet for localhost når PostgREST kører i Docker
# Password skal matche det sat i migrations/002_api_schema.sql
PGRST_DB_URI=postgresql://authenticator:skift-dette-password@host.docker.internal:5432/ladestander
